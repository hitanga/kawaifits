{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A fashion item in the store.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the product." },
        "title": { "type": "string", "description": "Name of the product." },
        "price": { "type": "number", "description": "Price in INR." },
        "shipping": { "type": "number", "description": "Shipping cost in INR." },
        "category": { "type": "string", "description": "Product category (e.g., Dresses, Tops)." },
        "image": { "type": "string", "description": "Main image URL." },
        "images": { "type": "array", "items": { "type": "string" }, "description": "Gallery image URLs." },
        "description": { "type": "string", "description": "Detailed product description." }
      },
      "required": ["title", "price", "category", "image", "description"]
    },
    "User": {
      "title": "User",
      "description": "A user of the platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User's role." }
      },
      "required": ["uid", "email", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique order ID." },
        "userUid": { "type": "string", "description": "UID of the user who placed the order." },
        "items": { "type": "array", "items": { "type": "object" }, "description": "List of items ordered." },
        "total": { "type": "number", "description": "Total order amount." },
        "status": { "type": "string", "enum": ["pending", "shipped", "delivered", "cancelled"], "description": "Order status." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Order timestamp." }
      },
      "required": ["userUid", "items", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products available in the store."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile information."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    }
  }
}
